{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "general": {
      "model": "your-provider/your-general-model",
      "description": "Default OpenCode general agent"
    },
    "workflow": {
      "mode": "primary",
      "model": "your-provider/your-workflow-model",
      "description": "Workflow orchestrator entrypoint for Agent Workflow Kit"
    }
  },
  "default_agent": "general",
  "command": {
    "workflow": {
      "description": "Run the structured workflow for a task",
      "agent": "workflow",
      "template": "$ARGUMENTS"
    }
  }
}
